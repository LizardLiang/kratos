{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook prompt-submit || ~/.kratos/bin/kratos hook prompt-submit",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.cjs\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PermissionRequest\",\"permissionDecision\":\"allow\",\"permissionDecisionReason\":\"Auto-allowed by Kratos plugin\"}}'",
            "timeout": 1000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook fix-pm 2>/dev/null || ~/.kratos/bin/kratos hook fix-pm",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/tool-use.cjs\"",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "kratos:ares",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook subagent-start 2>/dev/null || ~/.kratos/bin/kratos hook subagent-start",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:hephaestus",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook subagent-start 2>/dev/null || ~/.kratos/bin/kratos hook subagent-start",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:hermes",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook subagent-start 2>/dev/null || ~/.kratos/bin/kratos hook subagent-start",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:athena",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --init 2>/dev/null || ~/.kratos/bin/kratos check --init",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:apollo",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --init --stage 4-spec-review-sa 2>/dev/null || ~/.kratos/bin/kratos check --init --stage 4-spec-review-sa",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:artemis",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --init --stage 5-test-plan 2>/dev/null || ~/.kratos/bin/kratos check --init --stage 5-test-plan",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:hera",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --init --stage 7-prd-alignment 2>/dev/null || ~/.kratos/bin/kratos check --init --stage 7-prd-alignment",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:cassandra",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --init --stage 8-review 2>/dev/null || ~/.kratos/bin/kratos check --init --stage 8-review",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "kratos:daedalus",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --init --stage 3-decomposition 2>/dev/null || ~/.kratos/bin/kratos check --init --stage 3-decomposition",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "kratos:ares",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook subagent-stop 2>/dev/null || ~/.kratos/bin/kratos hook subagent-stop",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "kratos:hephaestus",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook subagent-stop 2>/dev/null || ~/.kratos/bin/kratos hook subagent-stop",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "kratos:hermes",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" hook subagent-stop 2>/dev/null || ~/.kratos/bin/kratos hook subagent-stop",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "kratos:athena",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --verify 2>/dev/null || ~/.kratos/bin/kratos check --verify",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "kratos:apollo",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --verify --stage 4-spec-review-sa 2>/dev/null || ~/.kratos/bin/kratos check --verify --stage 4-spec-review-sa",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "kratos:artemis",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --verify --stage 5-test-plan 2>/dev/null || ~/.kratos/bin/kratos check --verify --stage 5-test-plan",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "kratos:hera",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --verify --stage 7-prd-alignment 2>/dev/null || ~/.kratos/bin/kratos check --verify --stage 7-prd-alignment",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "kratos:cassandra",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --verify --stage 8-review 2>/dev/null || ~/.kratos/bin/kratos check --verify --stage 8-review",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "kratos:daedalus",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/kratos\" check --verify --stage 3-decomposition 2>/dev/null || ~/.kratos/bin/kratos check --verify --stage 3-decomposition",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end.cjs\"",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
