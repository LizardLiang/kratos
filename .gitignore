# Override global gitignore for docs/roadmap.md and README assets only
!docs/
docs/*
!docs/roadmap.md
!docs/assets/
!docs/assets/**

# Go build intermediates (bin/ is tracked for distribution)
go/kratos
go/bin/
*.dll

# Embedded asset copies — generated by `make build` from canonical sources.
# Canonical locations: agents/, templates/, command-mode-suffix/, references/agent-protocol-slices/
go/internal/cli/agents/
go/internal/cli/templates/
go/internal/cli/command-mode-suffix/
go/internal/cli/agent-protocol-slices/

# Test artifacts
*.test
*.out
coverage.txt
coverage.out
coverage.html

# Go workspace
go.work
go.work.sum

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Kratos runtime
.kratos/
active-session.json

# Python cache (legacy)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
memory/.pytest_cache/

# Node modules (hooks)
node_modules/

# Logs
*.log
